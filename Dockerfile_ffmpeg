# Use an FFmpeg image, but override its default entrypoint so the container
# starts our HTTP server instead of launching ffmpeg directly.
FROM jrottenberg/ffmpeg:8.1-scratch320

WORKDIR /app

# Copy the static HTTP server binary that shells out to ffmpeg.
COPY cf_container_ffmpeg_server /app/cf_container_ffmpeg_server

RUN mkdir -p /app/uploads /app/outputs

EXPOSE 8080

# The base image defines an ffmpeg entrypoint. Override it explicitly or the
# container will start as `ffmpeg cf_container_ffmpeg_server`.
ENTRYPOINT ["/app/cf_container_ffmpeg_server"]
